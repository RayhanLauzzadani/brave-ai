APP_NAME=BRAVE AI API
ENVIRONMENT=development
API_PREFIX=/api

DATABASE_URL=postgresql+asyncpg://brave:brave_password@localhost:5432/brave_ai
REDIS_URL=redis://localhost:6379/0

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://192.168.110.211:3000"]
MEDIA_BASE_URL=http://localhost:8000/media
MEDIA_HLS_BASE_URL=http://localhost:8888
MEDIA_RECORDINGS_DIR=/recordings
MEDIA_RECORD_SEGMENT_DURATION_SECONDS=60
MEDIA_RECORD_MIN_FILE_SIZE_BYTES=65536
MEDIA_CLIPS_DIR=/clips
EVIDENCE_CLIP_MAX_DURATION_SECONDS=600
EVIDENCE_CLIP_FFMPEG_TIMEOUT_SECONDS=180
EVIDENCE_CLIP_SOURCE_WAIT_SECONDS=120
FFMPEG_BINARY=ffmpeg
SECRET_KEY=change-this-development-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
